# Gregory - Smart House AI
# Copy to .env and configure for your environment
# For local (non-Docker) runs, you can instead use config.json (copy from config.json.example)

# Logging
LOG_LEVEL=INFO

# AI Provider - set one or more; AI_PROVIDER selects which to use (claude, gemini, ollama)
# If unset, first available wins: Claude > Gemini > Ollama

# Ollama (on-prem)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# Claude (Anthropic) - get key from https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Gemini (Google) - get key from https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-1.5-flash

# AI_PROVIDER=claude
# AI_PROVIDER=gemini
# AI_PROVIDER=ollama

# Notes observations - Gregory writes learned facts to notes (default: false)
# OBSERVATIONS_ENABLED=false

# Override base system prompt (omit to use default; use \n for newlines)
# SYSTEM_PROMPT=You are Gregory, a helpful assistant.

# Notes - path to Markdown notes directory (mounted volume in Docker)
NOTES_PATH=/app/notes

# Family members - comma-separated user IDs
FAMILY_MEMBERS=alice,bob,kids

# Memory system - daily journal files + vector DB for long-term recall (default: disabled)
# MEMORY_ENABLED=false
# MEMORY_PATH=/app/memory
# MEMORY_SIMILARITY_THRESHOLD=0.7
# MEMORY_TOP_K=3
# Embedding provider: 'default' (self-contained onnxruntime) or 'ollama' (requires OLLAMA_BASE_URL)
# MEMORY_EMBEDDING_PROVIDER=default
# MEMORY_EMBEDDING_MODEL=nomic-embed-text

# Heartbeat: journal summary (suggested: 1440 = once/day) and monthly compression (suggested: 10080 = weekly)
# HEARTBEAT_DAILY_SUMMARY_MINUTES=0
# HEARTBEAT_MEMORY_COMPRESSION_MINUTES=0

# Optional: path to JSON config file (for local runs)
# CONFIG_FILE=config.json
